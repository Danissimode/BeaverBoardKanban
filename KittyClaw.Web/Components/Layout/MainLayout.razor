@inherits LayoutComponentBase
@implements IDisposable
@inject KittyClaw.Web.Services.UpdateCheckService UpdateCheck

@Body

@if (UpdateCheck.HasUpdate)
{
    <div class="update-banner" role="status">
        <span class="update-banner-icon">✨</span>
        <span class="update-banner-text">
            A new version is available
            <a href="@($"https://github.com/Ekioo/KittyClaw/releases/tag/{UpdateCheck.LatestVersion}")"
               target="_blank" rel="noopener">@UpdateCheck.LatestVersion</a>
            (current: @UpdateCheck.CurrentVersion)
        </span>
        <button type="button" class="update-banner-dismiss" @onclick="OnDismiss" aria-label="Dismiss">✕</button>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized()
    {
        UpdateCheck.OnChange += HandleChange;
    }

    private void HandleChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnDismiss()
    {
        UpdateCheck.Dismiss();
    }

    public void Dispose()
    {
        UpdateCheck.OnChange -= HandleChange;
    }
}
